{
    "name": "danepliz/nepali-calendar-bundle",
    "description": "Symfony bundle for Nepali (Bikram Sambat) ↔ Gregorian date conversion with a Stimulus datepicker",
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Danepliz",
            "email": "dev@fitnechnepal.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "symfony/framework-bundle": "^6.4 || ^7.0",
        "symfony/twig-bundle": "^6.4 || ^7.0",
        "psr/log": "^2.0 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "symfony/cache": "^6.4 || ^7.0",
        "symfony/phpunit-bridge": "^6.4 || ^7.0"
    },
    "suggest": {
        "symfony/cache": "For PSR-6 caching of the calendar JSON data"
    },
    "autoload": {
        "psr-4": {
            "Danepliz\\NepaliCalendarBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Danepliz\\NepaliCalendarBundle\\Tests\\": "tests/"
        }
    },
    "extra": {
        "symfony": {
            "allow-contrib": false
        }
    },
    "config": {
        "sort-packages": true
    }
}
